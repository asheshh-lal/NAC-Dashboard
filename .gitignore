✅ New app.py
import streamlit as st
import pandas as pd

st.set_page_config(layout="wide")

st.title("Nepal Airlines vs Druk Air Dashboard")

# plane images
nepal_img = "https://upload.wikimedia.org/wikipedia/commons/3/3c/Nepal_Airlines_A330.jpg"
druk_img = "https://upload.wikimedia.org/wikipedia/commons/0/0c/Drukair_A319.jpg"

col1, col2 = st.columns(2)

with col1:
    st.image(nepal_img, caption="Nepal Airlines")

with col2:
    st.image(druk_img, caption="Druk Air")


st.header("Key Numbers")

nepal_passengers = 629147
nepal_domestic = 17214
nepal_market = 16.56

druk_passengers = 201979
druk_flights = 3996
druk_profit = 291

c1, c2, c3 = st.columns(3)

with c1:
    st.metric("Nepal Intl Passengers", nepal_passengers)

with c2:
    st.metric("Druk Passengers", druk_passengers)

with c3:
    st.metric("Druk Flights", druk_flights)


st.header("Comparison")

data = {
    "Category": ["Passengers", "Flights"],
    "Nepal Airlines": [629147, 0],
    "Druk Air": [201979, 3996],
}

df = pd.DataFrame(data)
df = df.set_index("Category")

st.bar_chart(df)


st.header("Nepal Airlines Info")

st.write("Market Share:", nepal_market, "%")
st.write("Domestic Passengers:", nepal_domestic)


st.header("Druk Air Info")

st.write("Passengers:", druk_passengers)
st.write("Flights:", druk_flights)
st.write("Profit Before Tax (million):", druk_profit)
